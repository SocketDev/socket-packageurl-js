{
  "permissions": {
    "allow": [
      "Bash(cat*)",
      "Bash(cp*)",
      "Bash(git*)",
      "Bash(grep*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(mv*)",
      "Bash(node*)",
      "Bash(pnpm*)"
    ],
    "deny": [
      "Bash(*> /dev/*)",
      "Bash(chmod 777*)",
      "Bash(chmod*)",
      "Bash(curl*)",
      "Bash(rm -rf*)",
      "Bash(ssh*)",
      "Bash(sudo*)",
      "Bash(wget*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-new-deps/index.mts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/token-hygiene/index.mts"
          }
        ]
      }
    ]
  }
}
