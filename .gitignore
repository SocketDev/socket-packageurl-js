# OS files
.DS_Store
._.DS_Store
Thumbs.db

# Environment & config
/.claude/*
!/.claude/agents/
!/.claude/commands/
!/.claude/ops/
!/.claude/skills/
/.env
/.env.local
/.env.*.local
/.node-version
