* text=auto eol=lf

# Vendored font binaries — don't diff, don't merge, don't
# EOL-normalize. Keeps `git diff`/`git log -p` readable when the
# woff2 bytes change on a font bump.
fonts/*.woff2 binary

# Build output — pages/ is entirely generated by scripts/tour.mts
# (rendered HTML, JS/CSS copies, AI-agent artifacts like
# llms.txt / llms-full.txt / *.md mirrors, vendored mermaid).
# Mark as generated metadata so GitHub PR views collapse these
# by default and diffs don't drown in build noise.
pages/** linguist-generated=true
pages/**.html -diff
pages/**.md -diff
pages/**.txt -diff
pages/style.css -diff
