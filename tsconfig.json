{
  "extends": "./.config/tsconfig.base.json",
  "compilerOptions": {
    "declarationMap": false,
    "module": "commonjs",
    "moduleResolution": "bundler",
    "noEmit": false,
    "noEmitOnError": false,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": false,
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage", "test"]
}
