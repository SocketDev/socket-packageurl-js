{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "commonjs",
    "moduleResolution": "bundler",
    "outDir": "../dist",
    "rootDir": "../src",
    "sourceMap": false,
    "types": ["node"],
    "verbatimModuleSyntax": false
  },
  "include": ["../src/**/*.ts"]
}
